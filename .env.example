GROQ_API_KEY = your Groq API key here

GROQ_MODEL= your Groq model name here (e.g., llama-2-7b-chat)       # LLM model served by Groq

CHROMA_PERSIST_DIR=./vectorstore                                    # Local ChromaDB storage path

EMBEDDING_MODEL=all-MiniLM-L6-v2                                    # Embedding model (runs 100% locally via sentence-transformers)

CHUNK_SIZE=500                                                      # Chunking settings
CHUNK_OVERLAP=50

TOP_K_RESULTS=3                                                     # How many chunks to retrieve per query